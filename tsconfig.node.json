{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "ES2022",
    "lib": ["ES2023", "DOM"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    // sharp 0.35.0's exports map lacks a "types" condition, so bundler resolution
    // misses its lib/index.d.ts (TS7016; fixed upstream in lovell/sharp#4537 but
    // unreleased). Remove once a newer sharp typechecks without it.
    "paths": {
      "sharp": ["./node_modules/sharp/lib/index.d.ts"]
    },
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "strictNullChecks": true
  },
  "include": ["vite.config.ts", "scripts/*.ts"]
}
