{
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "numberOfRuns": 3,
      "url": [
        "http://localhost/index.html",
        "http://localhost/guide/index.html",
        "http://localhost/resources/index.html",
        "http://localhost/flashcard/index.html",
        "http://localhost/spot-check/index.html",
        "http://localhost/acaan/index.html",
        "http://localhost/toolbox/index.html",
        "http://localhost/stats/index.html",
        "http://localhost/about/index.html"
      ]
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.9 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }],
        "categories:seo": ["warn", { "minScore": 0.9 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
