{
  "name": "memdeck.org",
  "private": true,
  "version": "0.0.1",
  "description": "Memorized Deck Tools",
  "type": "module",
  "homepage": "https://github.com/julienroussel/memdeck.org#readme",
  "bugs": {
    "url": "https://github.com/julienroussel/memdeck.org/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/julienroussel/memdeck.org.git"
  },
  "author": "Julien Roussel",
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=25",
    "pnpm": ">=10"
  },
  "scripts": {
    "knip": "knip",
    "lint": "ultracite check",
    "lint:e2e-no-wait": "if grep -rnE \"\\.\\s*waitForTimeout\\s*\\(\" --include='*.ts' --include='*.tsx' e2e/ ; then echo 'E2E tests must use semantic waits, not waitForTimeout. See .claude/rules/pwa-and-lazy-loading.md.' >&2; exit 1; fi",
    "fix": "ultracite fix",
    "dev": "vite",
    "build": "vite build && node scripts/generate-sitemap.ts && node scripts/generate-llms-whats-new.ts && node scripts/prerender.ts",
    "typecheck": "tsc -b",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "fta": "fta --config-path fta.json --json src",
    "lighthouse": "lhci autorun",
    "generate:splash": "node scripts/generate-splash-images.ts",
    "generate:screenshots": "node scripts/generate-screenshots.ts",
    "whats-new:draft": "node scripts/draft-whats-new.ts",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@lhci/cli": "0.15.1",
    "@playwright/test": "1.61.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.9",
    "fta-cli": "3.0.0",
    "globals": "17.6.0",
    "happy-dom": "20.10.5",
    "knip": "6.17.1",
    "lefthook": "2.1.9",
    "postcss": "8.5.15",
    "postcss-preset-mantine": "1.18.0",
    "postcss-simple-vars": "7.0.1",
    "sharp": "0.35.1",
    "typescript": "6.0.3",
    "ultracite": "7.8.3",
    "vite": "8.0.16",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "4.1.9",
    "workbox-window": "7.4.1"
  },
  "dependencies": {
    "@mantine/core": "9.3.2",
    "@mantine/hooks": "9.3.2",
    "@mantine/notifications": "9.3.2",
    "@tabler/icons-react": "3.44.0",
    "i18next": "26.3.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-error-boundary": "6.1.2",
    "react-ga4": "3.0.1",
    "react-i18next": "17.0.8",
    "react-router": "7.18.0",
    "web-vitals": "5.3.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "lefthook"
    ]
  }
}
